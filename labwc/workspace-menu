#!/bin/sh
# Workspace switcher menu via wofi
# Uses existing keybindings (A-1..4, A-S-1..4) via wtype

SELECTED=$(printf "Desktop 1\nDesktop 2\nDesktop 3\nDesktop 4\n───\nMove to Desktop 1\nMove to Desktop 2\nMove to Desktop 3\nMove to Desktop 4" \
    | wofi --dmenu \
        -s /home/hkaku/.config/TWM/wofi/style-menu.css \
        -c /dev/null \
        -l 8 \
        -W 220 \
        -p "Workspace" \
        -b -i)

case "$SELECTED" in
    "Desktop 1")         wtype -M Alt -k 1 -m Alt ;;
    "Desktop 2")         wtype -M Alt -k 2 -m Alt ;;
    "Desktop 3")         wtype -M Alt -k 3 -m Alt ;;
    "Desktop 4")         wtype -M Alt -k 4 -m Alt ;;
    "Move to Desktop 1") wtype -M Alt -M Shift -k 1 -m Shift -m Alt ;;
    "Move to Desktop 2") wtype -M Alt -M Shift -k 2 -m Shift -m Alt ;;
    "Move to Desktop 3") wtype -M Alt -M Shift -k 3 -m Shift -m Alt ;;
    "Move to Desktop 4") wtype -M Alt -M Shift -k 4 -m Shift -m Alt ;;
esac
